# diagnostic_engine.py
class WeldingRig:
    def __init__(self, rig_id, arc_hours):
        self.rig_id = rig_id
        self.arc_hours = arc_hours
        self.service_threshold = 500 # Service every 500 hours

    def check_status(self):
        remaining = self.service_threshold - (self.arc_hours % self.service_threshold)
        if remaining < 50:
            return f"CRITICAL: Rig {self.rig_id} needs service in {remaining} hours."
        return f"Rig {self.rig_id} is optimal. {remaining} hours until next service."

# Example for Pinnacle Manager
pinnacle_rig_01 = WeldingRig("PNCL-104", 485)
print(pinnacle_rig_01.check_status())
